# ─────────────────────────────────────────────────────────────────────────────
# WriteFlow AI — Environment Variables Template
# Copy this file to .env.local and fill in your values.
# NEVER commit .env or .env.local — they are gitignored.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string. Leave blank or remove to use the JSON fallback DB.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/writeflow?schema=public"

# ── NextAuth ──────────────────────────────────────────────────────────────────
# Required: random 32+ character secret for signing JWT session tokens.
# Generate one with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-random-32-char-secret"

# Required in development (set to your deployed URL in production)
NEXTAUTH_URL="http://localhost:3000"

# ── Google OAuth (optional) ───────────────────────────────────────────────────
# Get from https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── Anthropic Claude API ──────────────────────────────────────────────────────
# Get from https://console.anthropic.com
ANTHROPIC_API_KEY=""

# ── Clerk Auth (optional — only if using Clerk instead of NextAuth) ───────────
# Get from https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/register
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard/documents
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard/documents
