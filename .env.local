# Database connection string (PostgreSQL)
# Supplying a default non-empty string prevents Prisma Client initialization errors during next build
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/writeflow?schema=public"

# Google Gemini API Key
GEMINI_API_KEY=""

# Session Secret (for local cookie authentication)
SESSION_SECRET="writeflow_super_secret_session_key_32_chars_long_minimum"
