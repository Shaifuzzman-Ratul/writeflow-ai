# Database (PostgreSQL — leave as-is if using JSON fallback)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/writeflow?schema=public"

# Anthropic Claude API Key — get from https://console.anthropic.com
ANTHROPIC_API_KEY=""

# JWT Secret — used to sign session tokens (change this to a random 32+ char string in production)
JWT_SECRET="writeflow_jwt_secret_change_in_production_32ch"

# NextAuth Secret — required for JWT session signing
NEXTAUTH_SECRET="writeflow_nextauth_secret_32_chars_min_local"

# NextAuth URL — required in development
NEXTAUTH_URL="http://localhost:3000"
